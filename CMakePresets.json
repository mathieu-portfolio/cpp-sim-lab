{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (default generator)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (default generator)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-ninja",
      "displayName": "Debug (Ninja)",
      "inherits": "debug",
      "generator": "Ninja"
    },
    {
      "name": "release-ninja",
      "displayName": "Release (Ninja)",
      "inherits": "release",
      "generator": "Ninja"
    },
    {
      "name": "debug-vs2022",
      "displayName": "Debug (VS2022 + vcpkg)",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "release-vs2022",
      "displayName": "Release (VS2022 + vcpkg)",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug-ninja",
      "configurePreset": "debug-ninja"
    },
    {
      "name": "release-ninja",
      "configurePreset": "release-ninja"
    },
    {
      "name": "debug-vs2022",
      "configurePreset": "debug-vs2022",
      "configuration": "Debug"
    },
    {
      "name": "release-vs2022",
      "configurePreset": "release-vs2022",
      "configuration": "Release"
    }
  ]
}
